{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sk-compress",
  "version": "1.0.1",
  "identifier": "com.skcompress.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sk-compress",
        "width": 400,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "backgroundColor": "#000000",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/ffmpeg"]
  },
  "plugins": {}
}
