{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sk-convert",
  "version": "1.0.0",
  "identifier": "com.mediacompressor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sk-convert",
        "width": 500,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 500,
        "minHeight": 500,
        "backgroundColor": "#000000",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
